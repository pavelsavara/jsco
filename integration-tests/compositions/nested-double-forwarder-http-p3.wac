// Three P3 HTTP forwarders composed flat with an open upstream.
//
// Topology:  test → outer-fwd → middle-fwd → inner-fwd → host-supplied upstream
//
// The inner forwarder's `wasi:http/handler` import is left as a top-level
// import that the host satisfies (with a JS handler in tests).
package jsco:nested-double-forwarder-http-p3;

let inner  = new jsco:server-fwd-http-p3 { ... };
let middle = new jsco:server-fwd-http-p3 {
    "wasi:http/handler@0.3.0-rc-2026-03-15": inner["wasi:http/handler@0.3.0-rc-2026-03-15"],
    ...
};
let outer  = new jsco:server-fwd-http-p3 {
    "wasi:http/handler@0.3.0-rc-2026-03-15": middle["wasi:http/handler@0.3.0-rc-2026-03-15"],
    ...
};
export outer...;
