// Two forwarders composed with implementer — implementer satisfies inner forwarder's WASI imports
// for environment, exit, random, clocks. stdin/stdout/stderr pass through from host.
// Used by Scenario J
package jsco:double-forwarder-implementer;

let impl = new jsco:implementer { ... };
let inner = new jsco:forwarder {
    "wasi:cli/environment@0.2.11": impl["wasi:cli/environment@0.2.11"],
    "wasi:cli/exit@0.2.11": impl["wasi:cli/exit@0.2.11"],
    "wasi:random/random@0.2.11": impl["wasi:random/random@0.2.11"],
    "wasi:clocks/monotonic-clock@0.2.11": impl["wasi:clocks/monotonic-clock@0.2.11"],
    "wasi:clocks/wall-clock@0.2.11": impl["wasi:clocks/wall-clock@0.2.11"],
    ...
};
let outer = new jsco:forwarder { ...inner, ... };
export outer...;
