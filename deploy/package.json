{
    "name": "@pavelsavara/jsco",
    "version": "0.1.0",
    "description": "WebAssembly Component Model runtime for browsers and Node.js, with WASIp1/p2/p3 hosts",
    "main": "index.js",
    "type": "module",
    "types": "index.d.ts",
    "bin": {
        "jsco": "index.js"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "import": "./index.js"
        },
        "./wasip1-via-wasip3": {
            "types": "./wasip1-via-wasip3.d.ts",
            "import": "./wasip1-via-wasip3.js"
        },
        "./wasip2-via-wasip3": {
            "types": "./wasip2-via-wasip3.d.ts",
            "import": "./wasip2-via-wasip3.js"
        },
        "./wasip2-via-wasip3-node": {
            "types": "./wasip2-via-wasip3-node.d.ts",
            "import": "./wasip2-via-wasip3-node.js"
        },
        "./wasip3": {
            "types": "./wasip3.d.ts",
            "import": "./wasip3.js"
        },
        "./wasip3-node": {
            "types": "./wasip3-node.d.ts",
            "import": "./wasip3-node.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/pavelsavara/jsco.git"
    },
    "keywords": [
        "WASM",
        "WIT",
        "WASI",
        "Component",
        "WebAssembly",
        "polyfill",
        "wasi-preview-2",
        "wasi-preview-3",
        "jspi",
        "runtime",
        "component-model"
    ],
    "author": "Pavel Savara <pavel.savara@gmail.com>",
    "license": "Apache-2.0 WITH LLVM-exception",
    "bugs": {
        "url": "https://github.com/pavelsavara/jsco/issues"
    },
    "homepage": "https://github.com/pavelsavara/jsco#readme"
}